# Copy file này thành .env rồi điền API key của bạn vào
# Lệnh: copy .env.example .env   (Windows)
#        cp .env.example .env     (Mac/Linux)

# --- GreenNode MaaS (khuyến nghị cho Claw-a-thon) ---
# API Key MaaS được BTC gửi qua email. Agent dùng Bearer auth gọi endpoint Anthropic-compatible.
LLM_API_KEY=your_maas_api_key_here
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn
# Đổi model tại đây: minimax/minimax-m2.5 | qwen/qwen3-5-27b | google/gemma-4-31b-it
LLM_MODEL=minimax/minimax-m2.5

# --- Tùy chọn: chạy local bằng Anthropic API thật ---
# Nếu không đặt LLM_API_KEY, code sẽ fallback sang ANTHROPIC_API_KEY.
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
